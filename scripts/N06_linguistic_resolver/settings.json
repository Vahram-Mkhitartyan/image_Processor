{
  "node": "N06_linguistic_resolver",
  "normalization": {
    "lowercase": true,
    "keep_hyphen": false,
    "normalize_armenian_ligature": false
  },
  "letter_ngram_stats": {
    "enabled": true,
    "corpus_path": "datasets/word_level_ocr/armenian_word_frequencies.tsv",
    "max_words": 250000,
    "min_word_count": 1,
    "orders": [2, 3, 4],
    "smoothing": 0.1,
    "weight_mode": "log_count",
    "gibberish_z_threshold": -2.0,
    "unknown_character_ratio_threshold": 0.25
  },
  "ngram_candidate_repair": {
    "enabled": true,
    "max_changes": 2,
    "max_positions_to_consider": 6,
    "max_alternatives_per_position": 5,
    "max_suggestions": 12,
    "min_z_improvement": 0.15
  },
  "resolver": {
    "top_k": 8,
    "trusted_as_final": false
  }
}

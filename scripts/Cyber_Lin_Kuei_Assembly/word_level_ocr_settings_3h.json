{
  "model_name": "word_level_ocr_v0_1",
  "random_seed": 42,
  "dataset": {
    "matenadata_dir": "Matenadata",
    "label_map_path": "scripts/N05handwritten_ocr/character_detector/numeric_label_map.json",
    "word_frequency_path": "datasets/word_level_ocr/armenian_word_frequencies.tsv",
    "max_words": 150000,
    "min_word_length": 2,
    "max_word_length": 18,
    "train_samples": 225000,
    "validation_samples": 10000,
    "test_samples": 10000
  },
  "rendering": {
    "image_height": 32,
    "min_glyph_height": 22,
    "max_glyph_height": 30,
    "min_gap_px": -4,
    "max_gap_px": 2,
    "max_vertical_jitter_px": 2,
    "horizontal_padding_px": 8,
    "background_value": 255,
    "ink_value": 0,
    "baseline_jitter_px": 2,
    "bridge_probability": 0.72,
    "bridge_max_vertical_gap_px": 7,
    "bridge_thickness_px": 1,
    "bridge_curve_px": 2,
    "slant_probability": 0.65,
    "max_slant_px": 4,
    "glyph_rotation_probability": 0.75,
    "min_glyph_rotation_degrees": 1.0,
    "max_glyph_rotation_degrees": 4.0,
    "shared_word_rotation": true,
    "blur_probability": 0.35,
    "morph_probability": 0.35,
    "noise_probability": 0.25,
    "max_noise_pixels": 12,
    "crop_padding_jitter_px": 3,
    "tail_layout_enabled": true,
    "no_tail_height_ratio": [0.34, 0.43],
    "single_tail_height_ratio": [0.62, 0.76],
    "both_tail_height_ratio": [0.84, 0.97]
  },
  "training": {
    "batch_size": 64,
    "epochs": 8,
    "learning_rate": 0.001,
    "num_workers": 2,
    "gradient_clip": 5.0,
    "device": "auto",
    "length_auxiliary": {
      "enabled": true,
      "loss_weight": 0.12,
      "max_length_class": 24
    },
    "bridge_auxiliary": {
      "enabled": true,
      "loss_weight": 0.08,
      "max_bridge_count_class": 24
    },
    "boundary_auxiliary": {
      "enabled": true,
      "loss_weight": 0.05,
      "target_radius_steps": 1,
      "probability_threshold": 0.45
    }
  },
  "output": {
    "model_dir": "models/word_level_ocr_v0_1",
    "report_dir": "reports/word_level_ocr_v0_1",
    "debug_dir": "temp_processing/word_level_ocr_training_debug"
  }
}

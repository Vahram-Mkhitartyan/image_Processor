{
  "model_name": "scribetrace_word_v0_1",
  "random_seed": 42,
  "dataset": {
    "matenadata_dir": "Matenadata",
    "label_map_path": "scripts/N05handwritten_ocr/character_detector/numeric_label_map.json",
    "word_frequency_path": "datasets/word_level_ocr/armenian_word_frequencies.tsv",
    "max_words": 50000,
    "min_word_length": 2,
    "max_word_length": 18,
    "samples": 2000,
    "max_sequence_length": 18,
    "boundary_bin_count": 32
  },
  "rendering": {
    "image_height": 32,
    "min_glyph_height": 22,
    "max_glyph_height": 30,
    "min_gap_px": -4,
    "max_gap_px": 2,
    "max_vertical_jitter_px": 2,
    "horizontal_padding_px": 8,
    "background_value": 255,
    "ink_value": 0,
    "baseline_jitter_px": 2,
    "bridge_probability": 0.72,
    "bridge_max_vertical_gap_px": 7,
    "bridge_thickness_px": 1,
    "bridge_curve_px": 2,
    "slant_probability": 0.65,
    "max_slant_px": 4,
    "glyph_rotation_probability": 0.75,
    "min_glyph_rotation_degrees": 1.0,
    "max_glyph_rotation_degrees": 4.0,
    "shared_word_rotation": true,
    "blur_probability": 0.35,
    "morph_probability": 0.35,
    "noise_probability": 0.25,
    "max_noise_pixels": 12,
    "crop_padding_jitter_px": 3,
    "tail_layout_enabled": true,
    "no_tail_height_ratio": [0.34, 0.43],
    "single_tail_height_ratio": [0.62, 0.76],
    "both_tail_height_ratio": [0.84, 0.97]
  },
  "scribetrace": {
    "enabled": true,
    "save_debug": false,
    "save_json": false,
    "ink_threshold_mode": "binary",
    "fixed_threshold_value": 128,
    "minimum_ink_pixels": 4,
    "maximum_component_count_for_full_trace": 120,
    "minimum_trace_path_points": 4,
    "enable_theoretical_reconstruction": false
  },
  "training": {
    "test_ratio": 0.2,
    "validation_ratio": 0.125,
    "random_forest": {
      "n_estimators": 240,
      "max_depth": 28,
      "min_samples_leaf": 1,
      "max_features": "sqrt",
      "n_jobs": 2,
      "class_weight": null
    }
  },
  "output": {
    "dataset_jsonl": "datasets/scribetrace_word_v0_1/scribetrace_word_v0_1.jsonl.gz",
    "schema_path": "models/scribetrace_word_v0_1/scribetrace_word_schema.json",
    "export_report_path": "reports/scribetrace_word_v0_1/export_report.json",
    "model_dir": "models/scribetrace_word_v0_1",
    "report_dir": "reports/scribetrace_word_v0_1",
    "trace_temp_dir": "temp_processing/scribetrace_word_trace"
  }
}

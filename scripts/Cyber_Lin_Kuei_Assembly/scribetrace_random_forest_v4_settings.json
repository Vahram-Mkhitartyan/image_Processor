{
  "model_name": "scribetrace_random_forest_v4_0",
  "dataset_dir": "Matenadata",
  "label_map_path": "scripts/N05handwritten_ocr/character_detector/numeric_label_map.json",
  "scribetrace_module_root": "scripts",
  "output_dir": "models/scribetrace_random_forest_v4_0",
  "report_dir": "reports/scribetrace_random_forest_v4_0",
  "dataset_export_dir": "datasets/scribetrace_random_forest_v4_0",
  "num_classes": 78,
  "random_seed": 42,
  "default_limit_per_class": 10,
  "split": {
    "validation_ratio": 0.1,
    "test_ratio": 0.1
  },
  "dataset_normalization": {
    "size": 96,
    "polarity": "auto"
  },
  "aristotel": {
    "enabled": true,
    "seed": 42,
    "include_clean": true,
    "compress_jsonl": true,
    "variants_per_source": 1,
    "degradation_epochs": 1,
    "recipes": [
      "light_cut",
      "light_blur",
      "scanner_noise",
      "light_erosion"
    ]
  },
  "scribetrace": {
    "enabled": true,
    "save_debug": false,
    "save_json": false,
    "ink_threshold_mode": "binary",
    "fixed_threshold_value": 128,
    "minimum_ink_pixels": 4,
    "maximum_component_count_for_full_trace": 50,
    "minimum_trace_path_points": 4,
    "short_path_merge_max_angle_degrees": 35.0,
    "short_path_tangent_points": 3,
    "short_path_merge_min_advantage_degrees": 10.0,
    "local_extrema_min_prominence": 2,
    "local_extrema_min_spacing": 3,
    "enable_theoretical_reconstruction": true,
    "reconstruction_use_recognition_verification": false,
    "reconstruction_max_defense_hypotheses": 6,
    "reconstruction_gap_close_px": 3,
    "reconstruction_max_removed_ink_ratio": 0.18,
    "reconstruction_noise_max_component_area": 6,
    "reconstruction_noise_max_component_ratio": 0.04,
    "reconstruction_artifact_max_thickness_px": 1,
    "reconstruction_border_extension_px": 3
  },
  "random_forest": {
    "n_estimators": 500,
    "max_depth": 32,
    "max_leaf_nodes": 1024,
    "min_samples_split": 4,
    "min_samples_leaf": 1,
    "class_weight": "balanced_subsample",
    "max_features": "sqrt",
    "max_samples": 0.85,
    "n_jobs": 2,
    "verbose": 1
  }
}

{
  "model_name": "scribetrain_monster_v0_1",
  "random_seed": 42,
  "dataset": {
    "matenadata_dir": "Matenadata",
    "label_map_path": "scripts/N05handwritten_ocr/character_detector/numeric_label_map.json",
    "word_frequency_path": "datasets/word_level_ocr/armenian_word_frequencies.tsv",
    "max_words": 50000,
    "min_word_length": 2,
    "max_word_length": 18,
    "samples": 8000,
    "validation_samples": 1000,
    "test_samples": 1000,
    "boundary_bin_count": 64,
    "boundary_heatmap_radius": 2,
    "max_sequence_length": 18,
    "bridge_ink_threshold": 0.08
  },
  "rendering": {
    "image_height": 32,
    "min_glyph_height": 22,
    "max_glyph_height": 30,
    "min_gap_px": -4,
    "max_gap_px": 2,
    "max_vertical_jitter_px": 2,
    "horizontal_padding_px": 8,
    "background_value": 255,
    "ink_value": 0,
    "baseline_jitter_px": 2,
    "bridge_probability": 0.72,
    "bridge_max_vertical_gap_px": 7,
    "bridge_thickness_px": 1,
    "bridge_curve_px": 2,
    "slant_probability": 0.65,
    "max_slant_px": 4,
    "glyph_rotation_probability": 0.75,
    "min_glyph_rotation_degrees": 1.0,
    "max_glyph_rotation_degrees": 4.0,
    "shared_word_rotation": true,
    "blur_probability": 0.35,
    "morph_probability": 0.35,
    "noise_probability": 0.25,
    "max_noise_pixels": 12,
    "crop_padding_jitter_px": 3,
    "tail_layout_enabled": true,
    "no_tail_height_ratio": [
      0.34,
      0.43
    ],
    "single_tail_height_ratio": [
      0.62,
      0.76
    ],
    "both_tail_height_ratio": [
      0.84,
      0.97
    ]
  },
  "feature_extraction": {
    "threshold_value": 128,
    "endpoint_radius_px": 1,
    "junction_radius_px": 1
  },
  "training": {
    "epochs": 12,
    "batch_size": 96,
    "learning_rate": 0.001,
    "weight_decay": 0.0001,
    "hidden_size": 96,
    "num_layers": 2,
    "dropout": 0.15,
    "boundary_positive_weight": 2.0,
    "length_loss_weight": 0.35,
    "peak_threshold": 0.35,
    "peak_min_distance_bins": 2,
    "num_workers": 0,
    "device": "auto",
    "bridge_loss_weight": 0.2,
    "cut_safety_loss_weight": 0.2,
    "length_path_weight": 0.25,
    "length_penalty_strength": 2.0,
    "snap_radius_bins": 2,
    "utility_weights": {
      "peak_f1": 0.55,
      "peak_count_pm1": 0.25,
      "length_accuracy": 0.15,
      "path_top5_count_exact": 0.05
    }
  },
  "output": {
    "model_dir": "models/scribetrain_monster_v0_1",
    "report_dir": "reports/scribetrain_monster_v0_1",
    "max_boundary_debug_images": 12,
    "max_path_examples": 12,
    "path_top_k": 5
  }
